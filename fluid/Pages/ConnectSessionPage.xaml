<Page
    x:Class="fluid_general.Pages.ConnectSessionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:ui="http://schemas.modernwpf.com/2019"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800"
    Title="セッションに接続">

    <Grid Margin="24">
        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="セッションに接続 (子機モード)" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>
            
            <TextBlock Text="親機（サーバー）のIPアドレスを入力して接続します。接続中はローカルのデータベースではなく、親機のデータを直接読み書きします。" TextWrapping="Wrap" Margin="0,0,0,20" />

            <TextBlock
                Margin="0,0,0,10"
                FontSize="16"
                FontWeight="Bold"
                Text="親機への接続設定（子機モード）" />
            <TextBlock
                Margin="0,0,0,20"
                Text="他のPCで動いているFluid Generalのデータを使用して認証を行うことができます。同じネットワーク内に親機が存在する必要があります。"
                TextWrapping="Wrap" />

            <TextBox
                x:Name="ServerAddressTextBox"
                ui:ControlHelper.Header="親機のURL（例: http://192.168.1.10:5010/）"
                ui:ControlHelper.PlaceholderText="http://0.0.0.0:5010/" />

            <StackPanel Margin="0,20,0,0" Orientation="Horizontal">
                <Button
                    x:Name="ConnectButton"
                    Click="ConnectButton_Click"
                    Content="接続してテスト" />
                <Button
                    x:Name="DisconnectButton"
                    Margin="10,0,0,0"
                    Click="DisconnectButton_Click"
                    Content="接続を解除（親機モードに戻る）" />
            </StackPanel>

            <TextBlock x:Name="StatusTextBlock" Margin="0,20,0,0" FontWeight="Bold" />

            <Border Margin="0,30,0,0" BorderBrush="LightGray" BorderThickness="0,1,0,0">
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="同一ネットワーク内の親機を自動探索" FontWeight="Bold" Margin="0,0,0,10" />
                    <Button x:Name="SearchButton" Content="親機を検索" Click="SearchButton_Click" />
                    <ListBox x:Name="ParentListBox" Margin="0,10,0,0" MaxHeight="150" SelectionChanged="ParentListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Link" Margin="0,0,10,0" />
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="SearchStatusTextBlock" FontSize="12" Foreground="Gray" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
