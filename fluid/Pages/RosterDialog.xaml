<ui:ContentDialog
    x:Class="fluid_general.Pages.RosterDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ModernWpf.Controls;assembly=ModernWpf"
    xmlns:controls1="clr-namespace:ModernWpf.Controls;assembly=ModernWpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:fluid_general.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    Title="名簿の設定"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    PrimaryButtonText="保存"
    SecondaryButtonText="キャンセル"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="名簿名" />
            <TextBox x:Name="RosterNameTextBox" Margin="0,5,0,15" />
            <TextBlock Text="各項目の列番号（1から開始）を指定してください" Margin="0,0,0,5" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" MaxHeight="400">
            <ItemsControl x:Name="ColumnMappingsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding Label, Mode=TwoWay}" Margin="2" />
                            <TextBlock Grid.Column="1" Text="列目:" VerticalAlignment="Center" Margin="5,0" />
                            <ui:NumberBox Value="{Binding ColumnIndex, Mode=TwoWay}" Grid.Column="2" Width="60" Margin="2" Minimum="1" />
                            <Button Grid.Column="3" Content="削除" Click="DeleteField_Click" CommandParameter="{Binding}" Margin="5,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2" Content="項目を追加" Click="AddField_Click" Margin="0,10,0,0" />
    </Grid>
</ui:ContentDialog>
