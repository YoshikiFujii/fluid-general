<Page x:Class="fluid_general.Pages.DataMigrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.modernwpf.com/2019"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="データ移行">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="旧データからの移行ツール" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>
        
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,24">
            過去の fluid アプリで使用されていた XML 形式のイベントデータや名簿データを、
            新しい SQLite データベースにインポートします。
            この操作は親機モードでのみ実行してください。
        </TextBlock>

        <ScrollViewer Grid.Row="2">
            <StackPanel>
                <ui:ProgressBar x:Name="MigrationProgressBar" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed" Margin="0,0,0,12"/>
                <TextBox x:Name="LogTextBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="200"/>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="3" x:Name="StartMigrationButton" Content="データ移行を開始する" HorizontalAlignment="Right" Click="StartMigrationButton_Click" Margin="0,16,0,0" Style="{StaticResource AccentButtonStyle}"/>
    </Grid>
</Page>
