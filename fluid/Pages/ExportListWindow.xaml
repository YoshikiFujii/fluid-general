<Window
    x:Class="fluid_general.Pages.ExportListWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:fluid_general.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    Title="ExportListWindow"
    Width="450"
    Height="450"
    ui:ThemeManager.IsThemeAware="True"
    ui:TitleBar.Background="{StaticResource PrimaryHeaderBrush}"
    ui:WindowHelper.UseModernWindowStyle="True"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,10">
                <TextBlock
                    Margin="15,15,15,15"
                    FontSize="24"
                    Text="出席状況を出力する" />

                <TextBlock Margin="15,15,15,0" Text="出力する生徒" />
                <Grid Margin="15,0,15,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <CheckBox
                        x:Name="CheckedCheckBox"
                        Grid.Column="0"
                        Content="参加済み" />
                    <CheckBox
                        x:Name="UncheckedCheckBox"
                        Grid.Column="1"
                        Content="未参加"
                        IsChecked="True" />
                    <CheckBox
                        x:Name="NotAttendingCheckBox"
                        Grid.Column="2"
                        Content="不参加" />
                </Grid>

                <TextBlock Margin="15,15,15,0" Text="出力する生徒情報" />
                <ItemsControl x:Name="ColumnsItemsControl" Margin="15,0,15,15">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}" Width="140" Margin="0,0,10,5" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="15,15,15,0" Text="詳細情報 (同ファイルの[詳細情報]シートに書き込まれます。)" />
                <CheckBox
                    x:Name="detailCheckBox"
                    Margin="15,0,15,0"
                    Content="詳細情報"
                    IsChecked="True" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="1"
                Margin="15,15,15,15"
                HorizontalAlignment="Stretch"
                Click="ExportExcelFile"
                Content="出力" />
        </Grid>
    </Grid>
</Window>
