<ui:ContentDialog
    x:Class="fluid_general.Pages.DisplaySettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    Title="表示設定"
    PrimaryButtonText="保存"
    SecondaryButtonText="キャンセル"
    DefaultButton="Primary"
    mc:Ignorable="d">
    
    <Grid Width="400">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <TextBlock Text="表示する項目を選択・並び替えてください" Margin="0,0,0,10" />
            <ListBox x:Name="FieldsListBox" MaxHeight="400" SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,2" VerticalContentAlignment="Center" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
            <Button Click="MoveUp_Click" Margin="0,0,0,10" Width="40" ToolTip="上に移動">
                <ui:FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74A;" />
            </Button>
            <Button Click="MoveDown_Click" Width="40" ToolTip="下に移動">
                <ui:FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74B;" />
            </Button>
        </StackPanel>
    </Grid>
</ui:ContentDialog>
