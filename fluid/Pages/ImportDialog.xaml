<ui:ContentDialog
    x:Class="fluid_general.Pages.ImportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ModernWpf.Controls;assembly=ModernWpf"
    xmlns:controls1="clr-namespace:ModernWpf.Controls;assembly=ModernWpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:fluid_general.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    Title="一括状態変更"
    PrimaryButtonText="実行"
    SecondaryButtonText="キャンセル"
    PrimaryButtonClick="ExecuteBatchImport_Click"
    Loaded="ImportDialog_Loaded"
    mc:Ignorable="d">
    <StackPanel Width="400">
        <ProgressBar Name="progressBar" Height="4" Margin="0,0,0,15" Visibility="Collapsed" />
        
        <TextBlock Text="エクセルファイルのA列（1列目）のデータを利用して、リスト内の生徒を一括で状態変更します。" TextWrapping="Wrap" Margin="0,0,0,20"/>

        <TextBlock Text="エクセルファイル" FontWeight="SemiBold" Margin="0,0,0,5" />
        <Grid Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilePathTextBox" Grid.Column="0" IsReadOnly="True" Margin="0,0,10,0" />
            <Button Grid.Column="1" Content="参照" Click="BrowseFile_Click" />
        </Grid>

        <TextBlock Text="変更する状態" FontWeight="SemiBold" Margin="0,0,0,5" />
        <ComboBox x:Name="TargetStatusComboBox" Width="200" Margin="0,0,0,15" SelectedIndex="0">
            <ComboBoxItem Content="参加済み" />
            <ComboBoxItem Content="不参加" />
            <ComboBoxItem Content="未参加" />
        </ComboBox>

        <TextBlock Text="登録に使うカラム (一致条件)" FontWeight="SemiBold" Margin="0,0,0,5" />
        <ComboBox x:Name="MatchColumnComboBox" Width="200" Margin="0,0,0,20" />

        <Button Content="旧形式イベントファイル (.xml) のマージ" Click="ImportEventClick" HorizontalAlignment="Right" Background="Transparent" BorderBrush="Transparent" Foreground="Gray" />
    </StackPanel>
</ui:ContentDialog>
